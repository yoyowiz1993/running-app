# Copy this file to .env.local and fill in your values.
# Do not commit .env.local (it is gitignored).
#
# Frontend (running-goal-app) – used by Vite at build time and in dev.
# For Netlify, add these same names in: Site settings > Build & deploy > Environment.

# Supabase (required for login and data)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend API (Garmin + Nutrition). Optional if public/config.json has apiBaseUrl.
VITE_API_BASE_URL=https://your-backend.onrender.com
